{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 Start Certification Mastery Suite",
            "type": "shell",
            "command": "${workspaceFolder}/start.sh",
            "windows": {
                "command": "${workspaceFolder}/start.bat"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true,
                "clear": true
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "🛑 Stop Server",
            "type": "shell",
            "command": "echo",
            "args": ["Press Ctrl+C in the terminal to stop the server"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}